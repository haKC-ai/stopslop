# stopslop configuration. Copy to .env and fill in what you use.
# Every value here is optional: the deterministic layers need none of it.

# LLM auditor provider keys (leave empty to run deterministic-only)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Pinned model versions go into every report. Override only if you know the
# exact version string you want reproduced.
#ANTHROPIC_MODEL=claude-sonnet-4-6
#OPENAI_MODEL=gpt-4o-2024-08-06
#GEMINI_MODEL=gemini-1.5-pro-002

# Runtime limits
#STOPSLOP_MAX_CHARS=400000
#STOPSLOP_TIMEOUT_SEC=30
#STOPSLOP_BLOCK_PRIVATE_IPS=true
